@startuml DC_DiabCare
skinparam backgroundColor #FAFAFA
skinparam class {
  BackgroundColor #E0F4F4
  BorderColor #006B6B
  FontColor #003333
  FontSize 11
  HeaderBackgroundColor #006B6B
  HeaderFontColor #FFFFFF
  HeaderFontStyle bold
}
skinparam ArrowColor #006B6B
skinparam ArrowThickness 1.5
skinparam stereotypeCBackgroundColor #AADDDD
skinparam title {
  FontSize 18
  FontColor #006B6B
  FontStyle bold
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}

title Diagramme de Classes — DiabCare\nPlateforme de Suivi de la Santé pour Patients Diabétiques

' ═══════════════════════════════════════════════
'  ÉNUMÉRATIONS
' ═══════════════════════════════════════════════
enum TypeDiabete <<chaima>> {
  TYPE_1
  TYPE_2
  GESTATIONNEL
}

enum StatutRDV <<folla>> {
  EN_ATTENTE
  VALIDE
  ANNULE
  TERMINE
}

enum TypeAlerte <<ines>> {
  HYPOGLYCEMIE
  HYPERGLYCEMIE_LEGERE
  HYPERGLYCEMIE_SEVERE
}

enum ContexteMesure <<kenza>> {
  A_JEUN
  AVANT_REPAS
  APRES_REPAS
  AU_COUCHER
}

' ═══════════════════════════════════════════════
'  CLASSE ABSTRAITE / PARENT 
' ═══════════════════════════════════════════════
abstract class Utilisateur <<chaima>> {
  - id : int
  - nom : String
  - prenom : String
  - email : String
  - motDePasse : String
  - dateInscription : String
  --
  + seConnecter(email, mdp) : boolean
  + seDeconnecter() : void
  + afficherDetails() : void
  + {abstract} getRole() : String
  
}

' ═══════════════════════════════════════════════
'  HÉRITAGE —  chaima
' ═══════════════════════════════════════════════
class Patient <<chaima>> {
  - typeDiabete : TypeDiabete
  - dateNaissance : String
  - poids : double
  - medicaments : String
  - medecinReferentId : int
  --
  + sInscrire() : boolean
  + modifierProfil(poids, medicaments) : void
  + getRole() : String
  + getTypeDiabete() : TypeDiabete
 
}

class Medecin <<yassmine>> {
  - specialite : String
  - numeroOrdre : String
  --
  + getRole() : String
  + getSpecialite() : String
  + ajouterCommentaire(mesure, texte) : void
  + validerRendezVous(rdv) : void
  + refuserRendezVous(rdv, motif) : void
}

class Administrateur <<ines>> {
  - niveauAcces : int
  --
  + getRole() : String
  + gererCompte(utilisateur) : void
  + consulterStatistiques() : void
}

' ═══════════════════════════════════════════════
'  MESURE GLYCÉMIQUE — kenza
' ═══════════════════════════════════════════════
class MesureGlycemique <<kenza>> {
  - id : int
  - valeur : double
  - unite : String
  - contexte : ContexteMesure
  - dateHeure : String
  - patientId : int
  --
  + estValide() : boolean
  + convertirUnite() : double
  + afficherDetails() : void

}

class HistoriqueGlycemie <<kenza>> {
  - mesures : ArrayList<MesureGlycemique>
  - patientId : int
  --
  + ajouterMesure(mesure) : void
  + calculerMoyenne() : double
  + filtrerParContexte(contexte) : ArrayList
  + getMesuresDerniersJours(nbJours) : ArrayList
  + afficherHistorique() : void
 
}

' ═══════════════════════════════════════════════
'  RENDEZ-VOUS — folla
' ═══════════════════════════════════════════════
class RendezVous <<folla>> {
  - id : int
  - date : String
  - heure : String
  - motif : String
  - statut : StatutRDV
  - patientId : int
  - medecinId : int
  --
  + demanderRendezVous() : boolean
  + annuler(motif) : void
  + valider() : void
  + afficherDetails() : void
  
}

' ═══════════════════════════════════════════════
'  DASHBOARD MÉDECIN — yasmine
' ═══════════════════════════════════════════════
class DashboardMedecin <<yassmine>> {
  - medecinId : int
  - patients : ArrayList<Patient>
  --
  + ajouterPatient(patient) : void
  + retirerPatient(patientId) : void
  + afficherDashboard() : void
}

class CommentaireClinique <<yassmine>> {
  - id : int
  - texte : String
  - dateHeure : String
  - medecinId : int
  - mesureId : int
  --
  + afficherDetails() : void
  
}

' ═══════════════════════════════════════════════
'  ALERTES — ines
' ═══════════════════════════════════════════════
class Alerte <<ines>> {
  - id : int
  - type : TypeAlerte
  - message : String
  - dateHeure : String
  - patientId : int
  - traitee : boolean
  --
  + verifierSeuil(valeur) : TypeAlerte
  + envoyerNotification() : void
  + marquerTraitee() : void
  + afficherDetails() : void
  
}

class JournalAlertes <<ines>> {
  - alertes : ArrayList<Alerte>
  --
  + ajouterAlerte(alerte) : void
  + getAlertesNonTraitees() : ArrayList
  + getNbAlertesCritiques() : int
  + afficherJournal() : void
}

' ═══════════════════════════════════════════════
'  RELATIONS
' ═══════════════════════════════════════════════

' Héritage
Utilisateur <|-- Patient : hérite
Utilisateur <|-- Medecin : hérite
Utilisateur <|-- Administrateur : hérite

' Composition : Patient possède HistoriqueGlycemie
Patient "1" *--> "1" HistoriqueGlycemie : possède >

' Composition : HistoriqueGlycemie contient MesureGlycemique
HistoriqueGlycemie "1" *--> "0..*" MesureGlycemique : contient >

' Composition : DashboardMedecin contient Patients
DashboardMedecin "1" *--> "0..*" Patient : gère >

' Association : Médecin gère DashboardMedecin
Medecin "1" o--> "1" DashboardMedecin : consulte >

' Association : Patient demande RendezVous
Patient "1" o--> "0..*" RendezVous : demande >

' Association : Médecin valide RendezVous
Medecin "1" o--> "0..*" RendezVous : valide >

' Composition : MesureGlycemique génère Alerte
MesureGlycemique "1" ..> "0..1" Alerte : déclenche >

' Composition : JournalAlertes contient Alerte
JournalAlertes "1" *--> "0..*" Alerte : enregistre >

' Association : CommentaireClinique référence MesureGlycemique
CommentaireClinique "0..*" o--> "1" MesureGlycemique : commente >

' Association : Médecin rédige CommentaireClinique
Medecin "1" o--> "0..*" CommentaireClinique : rédige >

' Association enums
Patient ..> TypeDiabete : utilise
RendezVous ..> StatutRDV : utilise
Alerte ..> TypeAlerte : utilise
MesureGlycemique ..> ContexteMesure : utilise

' Notes
note right of Utilisateur : Classe abstraite commune\nà tous les acteurs du système
note bottom of HistoriqueGlycemie : Filtre les mesures\npar contexte ou période
note bottom of JournalAlertes : Seuils :\nhypo < 3.9 mmol/L\nhyper > 13.9 mmol/L

@enduml
