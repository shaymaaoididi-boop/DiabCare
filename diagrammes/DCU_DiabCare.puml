@startuml DCU_DiabCare
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

skinparam actor {
  BackgroundColor #005F5F
  FontColor #FFFFFF
  BorderColor #003333
  FontSize 13
}
skinparam usecase {
  BackgroundColor #E8F5F5
  BorderColor #006B6B
  FontColor #002222
  FontSize 11
}
skinparam ArrowColor #006B6B
skinparam ArrowThickness 1.5
skinparam PackageBorderColor #006B6B
skinparam PackageBackgroundColor #F5FFFE
skinparam PackageFontColor #004444
skinparam PackageFontSize 12
skinparam PackageFontStyle bold

title <b>Diagramme de Cas d'Utilisation — DiabCare</b>\nPlateforme de Suivi de la Santé pour Patients Diabétiques

' ═══════════════ ACTEURS ══════════════════
actor "Visiteur" as V
actor "Patient" as P
actor "Médecin" as M
actor "Administrateur" as A

' ═══════ HÉRITAGE DES ACTEURS ══════════
V <|-- P  : hérite
V <|-- M  : hérite

' ═══════════════ SYSTÈME ═════════════════
rectangle "Système DiabCare" {

  package "Accès Public" #E8F5F5 {
    (S'inscrire) as UC01
    (Se connecter) as UC02
    (Se déconnecter) as UC03
    (Consulter la page d'accueil) as UC04
  }

  package "Fonc. 1 : Authentification & Profil\n[chaima]" #FFF8E1 {
    (Gérer son profil médical) as UC05
    (Modifier poids et médicaments) as UC06
    (Consulter son profil) as UC07
  }

  package "Fonc. 2 : Mesures Glycémiques\n[kenza]" #E8F5E9 {
    (Enregistrer une mesure glycémique) as UC08
    (Valider la plage physiologique) as UC09
    (Consulter l'historique des mesures) as UC10
    (Filtrer l'historique par contexte) as UC11
    (Calculer la moyenne glycémique) as UC12
  }

  package "Fonc. 3 : Rendez-vous Médicaux\n[folla]" #FBE9E7 {
    (Demander un rendez-vous) as UC13
    (Annuler un rendez-vous) as UC14
    (Valider un rendez-vous) as UC15
    (Refuser un rendez-vous) as UC16
  }

  package "Fonc. 4 : Tableau de Bord Médecin\n[yassmine]" #EDE7F6 {
    (Consulter le tableau de bord patients) as UC17
    (Voir le détail d'un patient) as UC18
    (Ajouter un commentaire clinique) as UC19
  }

  package "Fonc. 5 : Alertes & Notifications\n[ines]" #FCE4EC {
    (Recevoir une alerte glycémique) as UC20
    (Vérifier le seuil critique) as UC21
    (Consulter le journal des alertes) as UC22
    (Gérer les comptes utilisateurs) as UC23
    (Consulter les statistiques globales) as UC24
  }
}

' ═══════════════ ASSOCIATIONS ════════════
' Visiteur
V --> UC01
V --> UC02
V --> UC04

' Patient
P --> UC03
P --> UC05
P --> UC08
P --> UC10
P --> UC13
P --> UC14
P --> UC20

' Médecin
M --> UC03
M --> UC15
M --> UC16
M --> UC17
M --> UC18
M --> UC19
M --> UC22

' Administrateur
A --> UC02
A --> UC03
A --> UC23
A --> UC24

' ═══════════════ INCLUDE / EXTEND ════════
UC08 ..> UC09 : <<include>>
UC08 ..> UC21 : <<include>>
UC10 ..> UC12 : <<include>>
UC05 ..> UC07 : <<include>>

UC01 ..> UC02 : <<include>>
UC10 ..> UC11 : <<extend>>
UC05 ..> UC06 : <<extend>>
UC17 ..> UC18 : <<extend>>
UC21 ..> UC20 : <<extend>>

@enduml
